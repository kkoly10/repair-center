# ─── Supabase ────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...   # preferred name (anon key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # fallback alias (same value)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe – repair payments ─────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...                # repair-payment webhook secret

# ─── Stripe – platform subscription billing ───────────────────────────────────
# Separate price and webhook from repair payments
STRIPE_BILLING_PRICE_ID=price_...             # Founder Beta $29/mo price ID
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...        # /api/billing/webhook signing secret

# ─── Stripe – Connect (per-shop payment accounts) ────────────────────────────
# Required when any shop uses payment_mode = 'stripe_connect'
# Dashboard: Stripe Connect → Webhooks → Create endpoint for account.updated
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...        # /api/billing/connect/webhook signing secret
# Optional: platform application fee rate on connected transactions (default 0.0075 = 0.75%)
STRIPE_CONNECT_PLATFORM_FEE_PERCENT=0.0075

# ─── Resend (transactional email) ────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=repairs@yourdomain.com              # must be a verified sender domain
NOTIFICATIONS_EMAIL_ENABLED=true               # set to false to suppress all email

# ─── Twilio (SMS notifications — optional) ───────────────────────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Full public URL of this deployment — no trailing slash
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# ─── Security ─────────────────────────────────────────────────────────────────
# HMAC secret for tamper-evident email links (rotate to invalidate old links)
# Optional but strongly recommended in production
EMAIL_LINK_SECRET=a-long-random-secret

# ─── Platform Admin Console ───────────────────────────────────────────────────
# Comma-separated list of email addresses allowed to access /platform/*
# If not set, /platform/* redirects to /admin/quotes
PLATFORM_ADMIN_EMAILS=you@example.com

# ─── Cron ────────────────────────────────────────────────────────────────────
# Bearer token checked by /api/cron/* endpoints
# If not set, cron endpoints are unauthenticated — set this in production
CRON_SECRET=a-long-random-secret

# ─── Multi-tenant defaults ────────────────────────────────────────────────────
# Slug used by legacy single-tenant routes (/estimate, /portal) as fallback
# Set to your organization's slug so those routes still work
NEXT_PUBLIC_DEFAULT_ORG_SLUG=your-shop-slug
DEFAULT_ORG_SLUG=your-shop-slug

# ─── Legal / contact ──────────────────────────────────────────────────────────
# Values shown on Terms, Privacy Policy, and Platform Terms pages.
# Set these before public launch.
NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com      # shown on /contact
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com    # shown on Platform Terms §17
NEXT_PUBLIC_PRIVACY_EMAIL=privacy@yourdomain.com    # shown on Privacy Policy §10, §14
NEXT_PUBLIC_BUSINESS_NAME=Acme Repair LLC            # legal entity name on Platform Terms §17
NEXT_PUBLIC_MAILING_ADDRESS=123 Main St, City, ST 00000  # mailing address on Privacy Policy §14
